# ex2ve synthetic test cases.
#
# Fixtures (input .e files) are generated by ./generate_inputs.py.
# All expected values below are derived analytically from the inputs.
# Output ordering is by (y, x) of the column's top-face centroid.

# 2x2x3 uniform mesh, all active, no barriers.
# Top-active run = all 3 layers in every column (equal dz=1 ⇒ simple mean for
# arithmetic; thickness-weighted harmonic for PERMZ).
simple_uniform:
  filename: simple_uniform.e
  type: assert
  assertions:
    num_elem: 4
    num_nodes: 9              # 3x3 grid of top-face nodes at z=3
    elem_vars:
      PORO: 0.2               # (0.1 + 0.3 + 0.2) / 3
      PERMX: 116.66666666666667    # (50 + 200 + 100) / 3 = 350/3
      PERMY: 116.66666666666667
      PERMZ: 8.571428571428571     # 3 / (1/5 + 1/20 + 1/10) = 3 / 0.35
      THICKNESS: 3.0
    sidesets:                 # 2x2 mesh ⇒ 2 boundary edges per cardinal
      south: 2
      east: 2
      north: 2
      west: 2
  rtol: 1.0e-12

# 2x2x4 mesh with the k=1 layer omitted ⇒ flow barrier at z=[1, 2].
# Top-active run is k=3 (top) + k=2 (above the gap). k=0 (below the gap) is
# discarded.
barrier:
  filename: barrier.e
  type: assert
  assertions:
    num_elem: 4
    num_nodes: 9              # top-face nodes at z=4
    elem_vars:
      PORO: 0.25              # (0.2 + 0.3) / 2
      PERMX: 150.0            # (100 + 200) / 2
      PERMY: 150.0
      PERMZ: 13.333333333333334    # 2 / (1/10 + 1/20) = 2 / 0.15
      THICKNESS: 2.0
    sidesets:
      south: 2
      east: 2
      north: 2
      west: 2
  rtol: 1.0e-12

# 2x2x2 mesh; each (i,j) column has distinct per-layer PORO.
# Output is sorted by (y, x) of the footprint, so columns appear in
# (0,0), (1,0), (0,1), (1,1) order ⇒ PORO means in [0.15, 0.20, 0.25, 0.10].
heterogeneous:
  filename: heterogeneous.e
  type: assert
  assertions:
    num_elem: 4
    num_nodes: 9
    elem_vars:
      PORO: [0.15, 0.20, 0.25, 0.10]
      THICKNESS: [2.0, 2.0, 2.0, 2.0]
    sidesets:
      south: 2
      east: 2
      north: 2
      west: 2
  rtol: 1.0e-12

# -----------------------------------------------------------------------------
# Edge cases
# -----------------------------------------------------------------------------

# Smallest viable input: a single cell. Exercises the no-averaging code path
# (single-element column ⇒ all means equal the cell's own value).
single_cell:
  filename: single_cell.e
  type: assert
  assertions:
    num_elem: 1
    num_nodes: 4
    elem_vars:
      PORO: 0.30
      PERMX: 75.0
      PERMY: 75.0
      PERMZ: 12.0       # harmonic of one value = the value itself
      THICKNESS: 2.0    # dz=2 in the fixture
    sidesets:           # one cell ⇒ all 4 edges are on the boundary
      south: 1
      east: 1
      north: 1
      west: 1
  rtol: 1.0e-12

# Middle-layer PERMZ=0 should drive the column's harmonic-mean PERMZ to 0,
# while arithmetic-mean properties are unaffected.
permz_zero:
  filename: permz_zero.e
  type: assert
  assertions:
    num_elem: 4
    num_nodes: 9
    elem_vars:
      PORO: 0.2                       # same as simple_uniform
      PERMX: 116.66666666666667
      PERMY: 116.66666666666667
      PERMZ: 0.0                      # harmonic short-circuit
      THICKNESS: 3.0
    sidesets:
      south: 2
      east: 2
      north: 2
      west: 2
  rtol: 1.0e-12

# Single HEX8 whose top face is a concave kite. CCW ordering can't rescue a
# non-convex set of 4 points, so the convexity check fires unconditionally.
twisted_quad:
  filename: twisted_quad.e
  type: exception
  expected_error: "non-convex top face"

# Non-HEX8 input (a single tetrahedron) is rejected at read time.
non_hex8:
  filename: non_hex8.e
  type: exception
  expected_error: "ex2ve requires HEX8 input"
